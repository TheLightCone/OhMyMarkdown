{
  "name": "oh-my-markdown",
  "version": "1.0.0",
  "description": "Windows Markdown 编辑器 - Typora 增强版",
  "main": "dist-electron/main.js",
  "author": "OhMyMarkdown",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/copy-vditor.mjs",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "preview": "vite preview",
    "electron:dev": "node scripts/copy-vditor.mjs && tsc -p tsconfig.electron.json && concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && electron-builder --win",
    "test": "node scripts/test-features.mjs && node scripts/test-vditor-integration.mjs && node scripts/test-outline.mjs && node scripts/test-interactions.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.12.0",
    "uuid": "^11.0.3",
    "vditor": "^3.10.9",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.ohmymarkdown.app",
    "productName": "OhMyMarkdown",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    }
  }
}
